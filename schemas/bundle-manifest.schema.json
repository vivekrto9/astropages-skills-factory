{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astropages.com/schemas/builder-skills/v1/bundle-manifest.schema.json",
  "title": "Builder skills bundle manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "builderVersion", "sourceCommit", "compatibleAiRuntime", "contentSha256", "files"],
  "properties": {
    "schemaVersion": { "const": "1" },
    "builderVersion": { "type": "string", "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$" },
    "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "compatibleAiRuntime": { "const": ">=1.24.0 <1.25.0" },
    "contentSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "files": {
      "type": "array",
      "maxItems": 1024,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "size", "sha256"],
        "properties": {
          "path": { "type": "string", "pattern": "^(?!/)(?!.*\\\\)(?!.*//)(?!.*(?:^|/)\\.\\.?(?:/|$))[^\\u0000]+$" },
          "size": { "type": "integer", "minimum": 0, "maximum": 1048576 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  }
}
