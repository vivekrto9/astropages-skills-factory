{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astropages.com/schemas/builder-skills/v1/template-evidence-record.schema.json",
  "title": "Builder skill template evidence record",
  "type": "object",
  "additionalProperties": false,
  "required": ["templateKey", "repository", "commit", "paths"],
  "properties": {
    "templateKey": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80 },
    "repository": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$", "maxLength": 120 },
    "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "paths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512,
        "pattern": "^(?!/)(?!.*\\\\)(?!.*//)(?!.*(?:^|/)\\.\\.?(?:/|$))[ -~]+$"
      }
    }
  }
}
