{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astropages.com/schemas/builder-skills/v1/intent.schema.json",
  "title": "Builder skill public intent",
  "type": "object",
  "additionalProperties": false,
  "required": ["key", "label", "categoryKey", "description", "aliases", "userExamples", "internalSkills", "toolDependencies"],
  "properties": {
    "key": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80 },
    "label": { "type": "string", "minLength": 1, "maxLength": 100, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F]+$" },
    "categoryKey": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 64 },
    "description": { "type": "string", "minLength": 1, "maxLength": 500, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F]+$" },
    "aliases": { "type": "array", "maxItems": 20, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F]+$" } },
    "userExamples": { "type": "array", "minItems": 1, "maxItems": 20, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 500, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F]+$" } },
    "internalSkills": { "type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" } },
    "toolDependencies": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "uniqueItems": true,
      "items": { "enum": ["emdash-mcp", "project-assets", "astrologyapi-mcp", "official-web-research", "project-secrets", "none"] }
    }
  }
}
